# Azure AI Foundry Project Endpoint
# Found in your Azure AI Foundry project settings
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>

# Model deployment name in your Azure AI project
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# Optional: Azure Monitor connection string for telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-key>;...

# Optional: override credential (leave blank to use DefaultAzureCredential)
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Demo mode: set to "true" to run without real Azure credentials
DEMO_MODE=true
